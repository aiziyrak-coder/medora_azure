# ================================================================
# Medora AI Backend — .env
# Domain: medoraapi.ziyrak.org  |  IP: 20.82.115.71
# ================================================================
# Production: When DEBUG=False, SECRET_KEY must be set (app will not start with default).
# Create superuser in production: set ADMIN_PASSWORD env (no default allowed when DEBUG=False).

SECRET_KEY=your-very-secret-key-change-this-in-production
DEBUG=False
# Bo'sh qoldirsangiz settings dagi default (* va barcha domenlar) ishlatiladi
ALLOWED_HOSTS=medoraapi.cdcgroup.uz,medora.cdcgroup.uz,medoraai.cdcgroup.uz,medoraapi.ziyrak.org,medora.ziyrak.org,20.82.115.71,167.71.53.238,localhost,127.0.0.1

# Database
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=/home/cdcgroup/medora_platform/app/backend/db.sqlite3

# CORS — Frontend domeniga ruxsat (HTTPS production)
CORS_ALLOWED_ORIGINS=https://medora.ziyrak.org,http://localhost:3000,http://localhost:5173

# HTTPS: True when Nginx serves SSL and sends X-Forwarded-Proto
SECURE_SSL_REDIRECT=True

# ── AI: faqat Gemini (Azure/OpenAI o'chirilgan) ─────────────────
# Serverda majburiy: Google AI Studio dan kalit oling va shu yerga kiriting.
GEMINI_API_KEY=

# ── Azure Speech (ovoz, ixtiyoriy) ──────────────────────────────
AZURE_SPEECH_KEY=YOUR_AZURE_SPEECH_KEY
AZURE_SPEECH_REGION=swedencentral
AZURE_SPEECH_ENDPOINT=https://swedencentral.api.cognitive.microsoft.com/

# ── Telegram ─────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_PAYMENT_GROUP_ID=YOUR_TELEGRAM_GROUP_ID

# ── Redis (ixtiyoriy) ────────────────────────────────────────
REDIS_URL=

AI_MODEL_DEFAULT=gemini-1.5-pro
